# =============================================================================
# EX-DIGITAL — Environment Variables Template
# =============================================================================
# Copy to .env and fill in production values BEFORE deploying.
# Never commit the .env file to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=exdigital
POSTGRES_USER=exdigital
POSTGRES_PASSWORD=changeme_strong_postgres_password

# The backend constructs DATABASE_URL from the above vars in docker-compose.
# For local dev (no Docker), set this manually:
DATABASE_URL=postgresql+asyncpg://exdigital:changeme@localhost:5432/exdigital

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED: Must be at least 32 random characters
JWT_SECRET=CHANGE_ME_replace_with_a_very_long_random_secret_at_least_64_chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# REQUIRED: Shared secret for HMAC signing with ERP gateway
HMAC_SECRET=CHANGE_ME_replace_with_strong_hmac_secret

# ── Gateway ───────────────────────────────────────────────────────────────────
GATEWAY_API_KEY=CHANGE_ME_replace_with_gateway_api_key
GATEWAY_PORT=5001
CORE_API_INTERNAL_URL=http://backend:8000
HMAC_TIMESTAMP_TOLERANCE=300

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Session Settings ──────────────────────────────────────────────────────────
SESSION_DURATION_MINUTES=10
SESSION_GRACE_PERIOD_MINUTES=5
QR_SCAN_WINDOW_MINUTES=5

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
